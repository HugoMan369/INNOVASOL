<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INNOVASOL</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family: 'Segoe UI', sans-serif;
    background:#0a0f1c;
    color:white;
}

/* OCULTAR SECCIONES */
.oculto{
    display:none;
}

/* HEADER */
header{
    background:#1b263b;
    padding:2rem;
    text-align:center;
}

header h1{
    color:#4cc9f0;
    font-size:3rem;
}

header p{
    font-size:1.5rem;
}

/* NAV */
nav{
    display:flex;
    justify-content:center;
    gap:10px;
    background:#14213d;
    padding:10px;
}

nav a{
    color:white;
    text-decoration:none;
    padding:8px 15px;
    border-radius:20px;
    font-size:1rem;
}

nav a:hover{
    background:#4cc9f0;
    color:black;
}

/* SECCIONES */
.seccion{
    padding:2rem;
    text-align:center;
}

.seccion h2{
    font-size:2.5rem;
    margin-bottom:20px;
}

.seccion p{
    font-size:1.3rem;
}

/* PRODUCTOS */
.productos{
    display:flex;
    flex-wrap:wrap;
    gap:1rem;
    justify-content:center;
}

.card{
    background:#1b263b;
    padding:1rem;
    border-radius:15px;
    width:300px;
    transition:.3s;
    display:flex;
    flex-direction:column;
    align-items:center;
    text-align:center;
}

.card:hover{
    transform:scale(1.05);
}

.card img{
    width:100%;
    height:200px;
    object-fit:cover;
    border-radius:10px;
    margin-bottom:10px;
}

.card h3{
    color:#4cc9f0;
    font-size:1.5rem;
    margin-bottom:5px;
}

.card p{
    font-size:1.2rem;
}

/* BOTÓN */
.btn{
    margin-top:20px;
    padding:10px 20px;
    background:#4cc9f0;
    border:none;
    border-radius:20px;
    cursor:pointer;
    font-size:1.2rem;
}

/* RESPONSIVE */
@media(max-width:768px){
    header h1{
        font-size:2.2rem;
    }
    header p{
        font-size:1.2rem;
    }
    .seccion h2{
        font-size:2rem;
    }
    .seccion p{
        font-size:1.1rem;
    }
    .card{
        width:90%;
    }
    .card img{
        height:180px;
    }
}

@media(max-width:480px){
    header h1{
        font-size:1.8rem;
    }
    header p{
        font-size:1rem;
    }
    .seccion h2{
        font-size:1.6rem;
    }
    .seccion p{
        font-size:1rem;
    }
    .card img{
        height:150px;
    }
    .card h3{
        font-size:1.3rem;
    }
    .card p{
        font-size:1rem;
    }
    .btn{
        font-size:1rem;
        padding:8px 15px;
    }
}
</style>
</head>

<body>

<header>
    <h1>INNOVASOL</h1>
    <p>Innovación en maquinaria ecológica</p>
</header>

<nav>
    <a href="#" onclick="mostrarInicio()">Inicio</a>
    <a href="#" onclick="mostrarProductos()">Productos</a>
    <a href="https://www.nationalgeographic.com/environment/article/biotechnology" target="_blank">Tecnología</a>
    <a href="https://www.google.com/maps" target="_blank">Ubicación</a>
    <a href="#" onclick="mostrarContacto()">Contacto</a>
</nav>

<!-- INICIO -->
<section id="inicio" class="seccion">
    <h2>Bienvenido a INNOVASOL</h2>
    <p>Maquinaria ecológica para el futuro, con eficiencia y tecnología de vanguardia.</p>
    <button class="btn" onclick="mostrarProductos()">Ver productos</button>
</section>

<!-- PRODUCTOS -->
<section id="productos" class="seccion oculto">
    <h2>Nuestros Productos</h2>

    <div class="productos">

        <div class="card">
            <img src="https://www.holcim.com.mx/sites/mexico/files/styles/teaser_2cols/public/2023-08/ecopact-teams-shoot-mexico.jpg.webp?h=2d8b8005&itok=q9Wefrhx" alt="Hormigonera Inteligente">
            <h3>Hormigonera Inteligente</h3>
            <p>$45,000 MXN</p>
            <p>Tecnología avanzada ecológica.</p>
        </div>

        <div class="card">
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSGfM5CWMY23wNEwYrdtvCoDCtc1Y7_YVP6Zw&s" alt="Grúa EcoLift">
            <h3>Grúa EcoLift</h3>
            <p>$120,000 MXN</p>
            <p>Eficiencia energética y sustentable.</p>
        </div>

        <div class="card">
            <img src="https://s.alicdn.com/@sc04/kf/A76d21ce5a2b746e1a970b4a5e96f8946A/Used-JCB-4CX-Eco-3CX-4DX-3CX-Mini-Tractor-with-Front-End-Loader-and-Backhoe-Retroexcavadora-JCB-1cx-3cx-4cx-4x4-Backhoe-Loader.jpeg_300x300.jpg" alt="Retroexcavadora BioTech">
            <h3>Retroexcavadora BioTech</h3>
            <p>$95,000 MXN</p>
            <p>Alta potencia ecológica para trabajos pesados.</p>
        </div>

    </div>

    <button class="btn" onclick="mostrarInicio()">⬅ Volver</button>
</section>

<!-- CONTACTO -->
<section id="contacto" class="seccion oculto">
    <h2>Contacto</h2>
    <p>📞 5619625557</p>
    <p>📧 hugobarreramurillo@gmail.com</p>
    <button class="btn" onclick="mostrarInicio()">⬅ Volver</button>
</section>

<script>
function mostrarInicio(){
    document.getElementById("inicio").classList.remove("oculto");
    document.getElementById("productos").classList.add("oculto");
    document.getElementById("contacto").classList.add("oculto");
}

function mostrarProductos(){
    document.getElementById("inicio").classList.add("oculto");
    document.getElementById("productos").classList.remove("oculto");
    document.getElementById("contacto").classList.add("oculto");
}

function mostrarContacto(){
    document.getElementById("inicio").classList.add("oculto");
    document.getElementById("productos").classList.add("oculto");
    document.getElementById("contacto").classList.remove("oculto");
}
</script>

</body>
</html>